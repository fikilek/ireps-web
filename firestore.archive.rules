rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSpu() {
      return signedIn() && request.auth.token.role == "SPU";
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isSelf(userId) || isSpu();
      allow list: if isSpu();
      allow create, update, delete: if isSpu();
    }

    match /{document=**} {
      allow read, write: if isSpu();
    }
  }
}
